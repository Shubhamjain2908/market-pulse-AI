{
  "name": "market-pulse-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Indian-markets (NSE/BSE) morning briefing agent. Pipeline: ingest -> enrich -> screen -> brief, with a swappable LLM provider.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.2",
  "main": "dist/cli.js",
  "bin": {
    "mp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/cli.ts migrate",
    "regime:signals": "tsx src/cli.ts regime-signals",
    "regime": "tsx src/cli.ts regime",
    "regime:classify": "tsx src/cli.ts regime:classify",
    "regime:gate-summary": "tsx src/cli.ts regime:gate-summary",
    "regime:seed-gates": "tsx scripts/seed-regime-gates.mts",
    "regime:audit-history": "tsx scripts/audit-regime-history.mts",
    "momentum:backfill-universe": "tsx scripts/backfill-momentum-universe.mts",
    "fundamentals:refresh": "tsx scripts/refresh-fundamentals-v2.mts",
    "fundamentals:audit": "tsx scripts/audit-fundamentals-coverage.mts",
    "momentum:refresh-earnings": "tsx scripts/refresh-earnings-calendar.mts",
    "cot:gold": "tsx scripts/cot-gold-fetch.ts",
    "momentum:rank": "tsx src/cli.ts momentum-rank",
    "momentum:rebalance": "tsx src/cli.ts momentum-rebalance",
    "backtest:option-a": "tsx src/backtest/runner.ts",
    "ingest": "tsx src/cli.ts ingest",
    "enrich": "tsx src/cli.ts enrich",
    "screen": "tsx src/cli.ts screen",
    "brief": "tsx src/cli.ts brief",
    "evaluate": "tsx src/cli.ts evaluate",
    "run-all": "tsx src/cli.ts run-all",
    "daily": "tsx src/cli.ts daily",
    "kite-login": "tsx src/cli.ts kite-login",
    "kite-auth": "tsx src/auth/kite-auth-server.ts",
    "kite-verify": "tsx src/cli.ts kite-verify",
    "scan": "tsx src/cli.ts scan",
    "schedule": "tsx src/cli.ts schedule",
    "healthcheck": "tsx deploy/healthcheck.ts",
    "llm:smoke:google-studio": "LLM_PROVIDER=google-studio tsx scripts/smoke-google-studio.mts",
    "llm:smoke:google-studio:flash": "LLM_PROVIDER=google-studio VERTEX_MODEL=gemini-2.5-flash tsx scripts/smoke-google-studio.mts",
    "prepare": "husky",
    "deploy": "pnpm build && pm2 reload deploy/ecosystem.config.cjs"
  },
  "keywords": [
    "stock-market",
    "nse",
    "bse",
    "india",
    "ai-agent",
    "trading",
    "briefing",
    "cursor-agent",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/genai": "^2.8.0",
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "croner": "^10.0.1",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "got": "^14.6.6",
    "juice": "^11.1.1",
    "nodemailer": "^9.0.0",
    "openai": "^6.39.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rss-parser": "^3.13.0",
    "tough-cookie": "^6.0.1",
    "yahoo-finance2": "^3.15.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild",
      "husky"
    ]
  }
}
