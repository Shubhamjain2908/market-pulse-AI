# =============================================================================
# Market Pulse AI - Environment Variables
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
# 'development' | 'production' | 'test'
NODE_ENV=development
# 'trace' | 'debug' | 'info' | 'warn' | 'error' | 'fatal'
LOG_LEVEL=info
# IANA timezone used for cron schedules and date computations
TZ=Asia/Kolkata

# --- Database --------------------------------------------------------------
# Path to the SQLite database file (created on first run)
DATABASE_PATH=./data/market-pulse.db

# --- LLM Provider ----------------------------------------------------------
# Which LLM backend to use for thesis + briefing composition.
# Supported: 'cursor-agent' | 'anthropic' | 'vertex' | 'openai' | 'mock'
# Recommended for production volume: 'vertex' (Gemini on Vertex AI — pay-as-you-go billing).
LLM_PROVIDER=cursor-agent

# --- cursor-agent (optional) -----------------------------------------------
# API key from https://cursor.com/docs/sdk/typescript#authentication
# Required for `cursor-agent` v3+ (the version shipped with Cursor 2026).
CURSOR_API_KEY=
# Path to the cursor-agent binary. Leave blank to auto-detect via PATH.
CURSOR_AGENT_BIN=
# Model slug for cursor-agent invocations (optional; uses default when blank).
CURSOR_AGENT_MODEL=
# Per-call timeout in ms. Long thesis prompts can take 30-60s.
CURSOR_AGENT_TIMEOUT_MS=120000

# --- Anthropic (optional) --------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Google Vertex AI / Gemini (recommended for large portfolios) ----------
# Uses Application Default Credentials: either set this to a service-account JSON path,
# or run: gcloud auth application-default login
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
# Model id — see https://cloud.google.com/vertex-ai/generative-ai/docs/learn/model-versions
# Default: gemini-2.5-flash (fast, cost-efficient). For heavier reasoning try gemini-2.5-pro.
VERTEX_MODEL=gemini-2.5-flash
# HTTP timeout per generateContent call (large prompts / JSON).
VERTEX_TIMEOUT_MS=180000

# Parallel LLM calls when analysing each portfolio holding (major speed-up vs sequential).
PORTFOLIO_ANALYSIS_CONCURRENCY=8
# '0' (default) — full LLM only when triggers fire (deep loss, alerts, news, screens, tech extremes).
# '1' — full JSON review on every holding (legacy / maximum spend).
PORTFOLIO_ANALYSIS_DISABLE_LITE=0
# Unrealised loss % at or below this triggers full portfolio LLM review (default -15).
PORTFOLIO_FULL_REVIEW_LOSS_PCT=-15
# '0' (default) — do not insert PORTFOLIO_ADD paper trades (negative historical expectancy).
# '1' — forward-test portfolio ADD recommendations in paper_trades.
PORTFOLIO_ADD_PAPER_TRADES=0

# --- OpenAI (optional) -----------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Broker / Market Data --------------------------------------------------
# Set to 'kite' to enable Zerodha Kite Connect for portfolio + live LTP.
# Daily ingest is fixed to Yahoo/NSE/Screener/RSS; this flag only affects live
# Kite-backed paths. Kite historical API is a paid add-on.
MARKET_DATA_PROVIDER=free
# Get keys at https://kite.trade > 'My Apps'
KITE_API_KEY=
KITE_API_SECRET=
# Local callback server for browser-based Kite login flow.
KITE_AUTH_PORT=3001
# Refreshed daily via `pnpm cli kite-login`. Tokens expire ~6 AM IST.
# Optional: absolute path to your env file (default = repo-root `.env`).
# MP_DOTENV_PATH=
KITE_ACCESS_TOKEN=
# Optional: pull portfolio holdings via Kite. Requires the three keys above.
PORTFOLIO_SOURCE=manual    # 'manual' (config/portfolio.json) | 'kite'

# --- News --------------------------------------------------------------
# Optional NewsAPI key. RSS feeds (ET, Moneycontrol) work without any key.
NEWS_API_KEY=

# --- External signal provider (optional) ---------------------------------
# JSON-RPC MCP URL and bearer token (thesis corroboration only; strategies in config/ext-signal-provider.json).
EXT_SIGNAL_ENDPOINT=
EXT_SIGNAL_API_KEY=

# --- Email Delivery (optional) ---------------------------------------------
# 'file' (default, writes HTML to ./briefings) | 'email'
BRIEFING_DELIVERY=file
BRIEFING_OUTPUT_DIR=./briefings
# Optional tuning (defaults shown). See `src/config/env.ts` for validation.
# BRIEFING_NEWS_WINDOW_HOURS=48
# BRIEFING_NEWS_LIMIT=20
# BRIEFING_MOOD_NARRATIVE=1
# THESIS_MAX_PER_RUN=5
# BRIEFING_RUN_SUMMARY_JSON=0
# INGEST_QUOTES_MAX_RETRIES=2

# Used when BRIEFING_DELIVERY=email. Use a Gmail App Password, not your
# main account password. https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# --- Scheduler --------------------------------------------------------------
# `pnpm schedule` runs recurring jobs in this timezone:
#   - Weekdays: 08:45 and 16:30
#   - Saturday: 08:00
