# =============================================================================
# Market Pulse AI — Oracle VM / production deploy
# Copy to the server as `.env` in the repo root (same as local development).
# See also repo-root `.env.example` for inline documentation of every variable.
# This file highlights what you need on a headless VM plus deploy-only knobs.
# =============================================================================

# --- Required for any real run ------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
TZ=Asia/Kolkata

# SQLite file (absolute path recommended on servers)
DATABASE_PATH=/opt/market-pulse-ai/data/market-pulse.db

# --- LLM (pick one backend and set its keys — same as laptop) ---------------
LLM_PROVIDER=vertex
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/opt/market-pulse-ai/secrets/vertex-sa.json
VERTEX_MODEL=gemini-2.5-flash
VERTEX_TIMEOUT_MS=180000

# --- Market data & portfolio --------------------------------------------------
MARKET_DATA_PROVIDER=free
PORTFOLIO_SOURCE=manual
# Kite (optional): copy token from laptop after `pnpm kite-login` or run login on VM
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=

# --- Briefing delivery (VM should use email) ----------------------------------
BRIEFING_DELIVERY=email
BRIEFING_OUTPUT_DIR=/opt/market-pulse-ai/briefings
# Strongly recommended: enables thesis failure detection in deploy/healthcheck.ts
BRIEFING_RUN_SUMMARY_JSON=1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# --- Ops / healthcheck (read by deploy/healthcheck.ts only) -------------------
# One-line audit log (TSV: time, OK|FAIL, date, detail)
HEALTHCHECK_LOG=/opt/market-pulse-ai/deploy/logs/health.log
# Comma-separated PM2 log files to scan for pino error lines (today, IST)
# Defaults under deploy/logs/ if unset — see deploy/ecosystem.config.cjs
# HEALTHCHECK_PIPELINE_LOG=/opt/market-pulse-ai/deploy/logs/pm2-combined.log
# Override recipient for failure alerts (defaults to SMTP_TO)
# HEALTHCHECK_ALERT_TO=you@example.com
# HEALTHCHECK_ALERT_SUBJECT_PREFIX=[Market Pulse VM]

# --- Optional: load .env from a fixed path (cron / pm2) -----------------------
# MP_DOTENV_PATH=/opt/market-pulse-ai/.env

# --- News (optional) ----------------------------------------------------------
# NEWS_API_KEY=

# --- Slack / Telegram (optional) --------------------------------------------
# SLACK_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
